{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ],
            "env": [
                "DATABASE_URL",
                "AUTH_SECRET",
                "AUTH_GOOGLE_ID",
                "AUTH_GOOGLE_SECRET",
                "AUTH_TWITTER_ID",
                "AUTH_TWITTER_SECRET",
                "AI_PROVIDER",
                "OPENAI_API_KEY",
                "GEMINI_API_KEY",
                "ANTHROPIC_API_KEY",
                "LEMONSQUEEZY_API_KEY",
                "LEMONSQUEEZY_STORE_ID",
                "LEMONSQUEEZY_PRO_VARIANT_ID",
                "NEXT_PUBLIC_APP_URL"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^build"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ]
        },
        "generate": {
            "cache": false
        }
    }
}