{
    "manifest_version": 3,
    "name": "Synk - Save Once, Find Instantly",
    "version": "1.0.0",
    "description": "Save all your tabs in one click. Organize with AI. Never lose a link again.",
    "permissions": [
        "tabs",
        "activeTab",
        "scripting",
        "cookies",
        "storage"
    ],
    "host_permissions": [
        "http://localhost:3000/*",
        "https://synk.ai/*",
        "https://*.synk.ai/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "commands": {
        "save-all-tabs": {
            "suggested_key": {
                "default": "Ctrl+Shift+S",
                "mac": "Command+Shift+S"
            },
            "description": "Save all open tabs to Synk"
        }
    }
}